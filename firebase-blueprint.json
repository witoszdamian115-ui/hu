{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPlus": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "userId", "role", "content", "createdAt"]
    },
    "Gem": {
      "title": "Gem",
      "description": "A custom AI persona or prompt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat."
    },
    "/gems/{gemId}": {
      "schema": "Gem",
      "description": "User-created Gems."
    }
  }
}
